{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2020",
    "types": ["node"],
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "skipLibCheck": true
  }
}
